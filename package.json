{
  "name": "naac-ssr-verifier",
  "version": "2.0.0",
  "description": "NAAC SSR Proof Authenticity Verifier — Production (Azure AI / Claude)",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm":  ">=8.0.0"
  },
  "scripts": {
    "build":        "cd frontend && npm install && npm run build",
    "start":        "node server/index.js",
    "dev":          "concurrently -n server,frontend -c red,cyan \"npm run dev:server\" \"npm run dev:frontend\"",
    "dev:server":   "node --watch server/index.js",
    "dev:frontend": "cd frontend && npm run dev",
    "install:all":  "npm install && cd frontend && npm install"
  },
  "dependencies": {
    "@azure-rest/ai-inference": "^1.0.0-beta.6",
    "@azure/core-auth":         "^1.7.2",
    "cors":                     "^2.8.5",
    "dotenv":                   "^16.4.5",
    "express":                  "^4.19.2",
    "express-rate-limit":       "^7.4.1",
    "helmet":                   "^7.1.0",
    "multer":                   "^1.4.5-lts.1",
    "pdf-parse":                "^1.1.1"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
