# ──────────────────────────────────────────────────────────────
# NAAC SSR Verifier — Environment Variables
# Copy this to .env and fill in your values.
# NEVER commit .env to git — it contains secrets.
# ──────────────────────────────────────────────────────────────

# ── REQUIRED — Azure AI (Claude on Azure) ─────────────────────

# Your Azure AI endpoint URL.
# Found in: Azure Portal → your AI resource → Overview → Endpoint
# Format: https://<resource-name>.services.ai.azure.com
AZURE_AI_ENDPOINT=https://YOUR-RESOURCE-NAME.services.ai.azure.com

# Your Azure AI API key.
# Found in: Azure Portal → your AI resource → Keys and Endpoint → Key 1
AZURE_AI_KEY=your_azure_ai_key_here

# ── OPTIONAL ──────────────────────────────────────────────────

# Claude model name as deployed in Azure AI Foundry.
# Check your deployment name in: Azure AI Foundry → Deployments
# Common values:
#   claude-sonnet-4-5   (default — best balance of speed and accuracy)
#   claude-opus-4-5     (most thorough, slower, costs more credits)
AZURE_AI_MODEL=claude-sonnet-4-5

# Server port (Render sets this automatically — leave blank)
PORT=3000

# Set to "production" when deploying
NODE_ENV=production

# Restrict which frontend origins can call the API.
# Leave blank during development (allows all origins).
# In production on Render: set to your Render URL.
# Example: ALLOWED_ORIGINS=https://naac-ssr-verifier.onrender.com
ALLOWED_ORIGINS=
